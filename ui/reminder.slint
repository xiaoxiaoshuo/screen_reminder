import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component ReminderWindow inherits Window {
    title: "屏幕提醒";
    always-on-top: true;
    no-frame: true;
    background: #1e1b4b;

    // 窗口几何
    in property <length> window-w: 720px;
    in property <length> window-h: 420px;

    // 卡片几何（由 Rust 计算传入）
    in property <length> card-x: 20px;
    in property <length> card-y: 20px;
    in property <length> card-w: 680px;
    in property <length> card-h: 380px;

    // 内容
    in property <bool> fullscreen-reminder: false;
    in property <string> reminder-title: "提醒";
    in property <string> reminder-message: "到时间了";
    in property <string> reminder-time: "";
    in property <bool> close-on-escape: true;

    callback dismissed();
    callback snooze();

    forward-focus: key-layer;

    // 关键点：FocusScope 必须包住整个提醒窗口。
    // 如果它只是一个 0x0 的兄弟节点，按钮获得焦点后，Esc 事件可能不会经过它。
    key-layer := FocusScope {
        x: 0px;
        y: 0px;
        width: root.window-w;
        height: root.window-h;
        focus-on-click: true;
        focus-on-tab-navigation: true;

        // capture-key-pressed 比 key-pressed 更早执行，能在按钮/子控件处理前拦截 Esc。
        capture-key-pressed(event) => {
            if (root.close-on-escape && event.text == Key.Escape) {
                root.dismissed();
                return accept;
            }
            return reject;
        }

        // 背景铺满窗口
        bg := Rectangle {
            x: 0px;
            y: 0px;
            width: root.window-w;
            height: root.window-h;
            background: @linear-gradient(135deg, #312e81 0%, #7c2d12 52%, #0f172a 100%);

            // 顶部彩色条
            Rectangle {
                x: 0px;
                y: 0px;
                width: root.window-w;
                height: 8px;
                background: @linear-gradient(90deg, #fbbf24 0%, #fb7185 45%, #60a5fa 100%);
            }
        }

        // 卡片 - 位置和尺寸都由 Rust 传入
        card := Rectangle {
            x: root.card-x;
            y: root.card-y;
            width: root.card-w;
            height: root.card-h;
            background: #fff7ed;
            border-radius: 28px;
            border-width: 3px;
            border-color: #fbbf24;

            Rectangle {
                x: 18px;
                y: 18px;
                width: parent.width - 36px;
                height: parent.height - 36px;
                background: #fffbeb;
                border-radius: 22px;
                border-width: 1px;
                border-color: #fed7aa;

                VerticalBox {
                    x: 42px;
                    y: 34px;
                    width: parent.width - 84px;
                    height: parent.height - 68px;
                    spacing: 14px;

                    Rectangle {
                        height: 68px;
                        background: #dc2626;
                        border-radius: 18px;

                        Text {
                            width: 100%;
                            height: 100%;
                            text: "⏰ " + root.reminder-title;
                            color: #ffffff;
                            font-size: 38px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: root.reminder-time;
                        color: #9a3412;
                        font-size: 16px;
                        font-weight: 600;
                        horizontal-alignment: center;
                    }

                    Rectangle {
                        background: #ffffff;
                        border-radius: 18px;
                        border-width: 1px;
                        border-color: #fed7aa;

                        Text {
                            x: 22px;
                            y: 14px;
                            width: parent.width - 44px;
                            height: parent.height - 28px;
                            text: root.reminder-message;
                            color: #1f2937;
                            font-size: 28px;
                            font-weight: 700;
                            wrap: word-wrap;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: root.close-on-escape ? "按 Esc 关闭提醒（程序保留在托盘）" : "请点击按钮处理提醒";
                        color: #78716c;
                        font-size: 14px;
                        horizontal-alignment: center;
                    }

                    HorizontalBox {
                        spacing: 18px;
                        alignment: center;

                        Button {
                            text: "5 分钟后再提醒";
                            clicked => { root.snooze(); }
                        }

                        Button {
                            text: "我知道了";
                            clicked => { root.dismissed(); }
                        }
                    }
                }
            }
        }
    }
}
